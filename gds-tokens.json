        "button": {
          "$type": "shadow",
          "$description": "Standard solid drop shadow for GDS buttons",
          "$value": [
            {
              "offsetX": "0",
              "offsetY": "3",
              "blur": "0",
              "spread": "0",
              "color": "#002d18",
              "inset": false
            }
          ]
        },
        "focus-ring-yellow": {
          "$type": "shadow",
          "$description": "Standard yellow focus ring spread",
          "$value": [
            {
              "offsetX": "0",
              "offsetY": "0",
              "blur": "0",
              "spread": "3",
              "color": "{govuk.colour.yellow}",
              "inset": false
            }
          ]
        },
        "focus-ring-black": {
          "$type": "shadow",
          "$description": "Outer black border for high-contrast focus states",
          "$value": [
            {
              "offsetX": "0",
              "offsetY": "0",
              "blur": "0",
              "spread": "5",
              "color": "{govuk.colour.black}",
              "inset": false
            }
          ]
        }
